{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "data/schemas/defenses.schema.json",
  "title": "Defense System Catalog Schema",
  "description": "Validates the catalog.json file defining available air defense systems.",
  "type": "object",
  "required": ["systems"],
  "additionalProperties": false,
  "properties": {

    "$schema": { "type": "string" },

    "systems": {
      "type": "array",
      "description": "List of all available air defense systems.",
      "items": { "$ref": "#/definitions/DefenseSystem" }
    }
  },

  "definitions": {

    "DefenseSystem": {
      "type": "object",
      "required": ["id", "name", "range_km", "batteries", "armament", "threats"],
      "additionalProperties": false,
      "properties": {

        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique identifier. Lowercase letters, digits, and underscores; must start with a letter."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Full display name of the system."
        },
        "range_km": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum engagement range in kilometers."
        },
        "batteries": {
          "type": "integer",
          "minimum": 1,
          "description": "Default number of batteries deployed when this system is added to a target."
        },
        "armament": {
          "$ref": "#/definitions/Armament"
        },
        "threats": {
          "type": "array",
          "description": "Threat types this system is designed to engage.",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["ballistic_missile", "cruise_missile", "drone"]
          }
        }
      }
    },

    "Armament": {
      "type": "object",
      "required": ["type", "name", "payload_kg", "kill_modality", "standard_loadout"],
      "additionalProperties": false,
      "properties": {

        "type": {
          "type": "string",
          "enum": ["missile", "gun", "laser", "microwave", "aircraft", "electronic"],
          "description": "Category of weapon."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the specific interceptor, round, or weapon."
        },
        "payload_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Warhead or projectile mass in kilograms. Use 0 for directed-energy weapons."
        },
        "kill_modality": {
          "type": "string",
          "enum": ["hit-to-kill", "fragmentation", "kinetic", "directed-energy", "jamming"],
          "description": "How the weapon destroys its target. Must be consistent with armament type."
        },
        "standard_loadout": {
          "type": "integer",
          "minimum": 1,
          "description": "Total rounds or missiles available per battery."
        }
      },

      "if":   { "properties": { "type": { "const": "missile" } }, "required": ["type"] },
      "then": { "properties": { "kill_modality": { "enum": ["hit-to-kill", "fragmentation"] } } },
      "else": {
        "if":   { "properties": { "type": { "const": "gun" } }, "required": ["type"] },
        "then": { "properties": { "kill_modality": { "enum": ["kinetic"] } } },
        "else": { "properties": { "kill_modality": { "enum": ["directed-energy"] } } }
      }
    }
  }
}
